generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Expense {
  id          String        @id @default(cuid())
  description String
  amount      Float
  category    String        @default("")
  isRecurring Boolean       @default(false)
  isSalary    Boolean       @default(false)
  status      ExpenseStatus @default(PENDING)
  date        DateTime      @default(now())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  userId      String
  talentId    String?
  user        User          @relation(fields: [userId], references: [id])
  talent      Talent?       @relation(fields: [talentId], references: [id])
  payment     Payment?

  @@index([date])
  @@index([isRecurring])
  @@index([isSalary])
  @@index([status])
  @@index([userId])
  @@index([talentId])
}

model Payment {
  id                 String      @id @default(cuid())
  amount             Float
  type               PaymentType
  description        String
  date               DateTime    @default(now())
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  userId             String
  expenseId          String?     @unique
  paypalTransactionId String?
  paypalEmail        String?
  user               User        @relation(fields: [userId], references: [id])
  expense            Expense?     @relation(fields: [expenseId], references: [id])

  @@index([date])
  @@index([type])
  @@index([userId])
}

enum ExpenseStatus {
  PENDING
  PAID
}

enum PaymentType {
  SALARY
  EXPENSE
}

model User {
  id                 String         @id @default(cuid())
  email              String?
  paypalEmail        String?
  password           String
  mustChangePassword Boolean        @default(true)
  frozen             Boolean        @default(false)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  salary             Float
  types              UserType[]
  permission         UserPermission
  username           String         @unique
  manager            Manager?
  talent             Talent?
  payments           Payment[]
  expenses           Expense[]
  editedVideos       Video[]

  @@index([username])
}

enum TalentStatus {
  ACTIVE
  FROZEN
  GRADUATED
}

model Talent {
  id                   String             @id @default(cuid())
  name                 String
  status               TalentStatus       @default(ACTIVE)
  contractDate         DateTime           @default(now())
  annualBudget         Float              @default(1000)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  twitch               String?
  youtube              String?
  tiktok               String?
  instagram            String?
  twitter              String?
  googleRefreshToken   String?
  googleAccessToken    String?
  googleTokenExpiresAt DateTime?
  userId               String?            @unique
  expenses             Expense[]
  incomes              Income[]
  videos               Video[]
  managers             Manager[]
  user                 User?              @relation(fields: [userId], references: [id])
  viewerPoints         ViewerPoints[]
  pointTransactions    PointTransaction[]
  pointConfig          PointConfig?

  @@index([name])
  @@index([contractDate])
}

model Manager {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String?  @unique
  user      User?    @relation(fields: [userId], references: [id])
  talents   Talent[]

  @@index([name])
}

enum UserPermission {
  ADMIN
  MANAGER
  USER
}

enum UserType {
  TALENT
  MANAGER
  STAFF
  EDITOR
}

enum IncomePlatform {
  YOUTUBE
  TWITCH
  STREAMLOOTS
  KOFI
  MERCHANDISE
  PAYPAL
  ADJUSTMENT
}

model Income {
  id              String         @id @default(cuid())
  accountingMonth DateTime
  platform        IncomePlatform
  currency        String         @default("USD")
  referenceValue  Float
  actualValue     Float
  actualValueUSD  Float
  description     String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  talentId        String
  talent          Talent         @relation(fields: [talentId], references: [id])

  @@index([talentId])
  @@index([accountingMonth])
  @@index([platform])
}

enum VideoStatus {
  GUIONADO
  CORRECCIONES
  GRABANDO
  EDITANDO
  TERMINADO
}

enum VideoType {
  SHORT
  LARGO
}

model Video {
  id        String      @id @default(cuid())
  titulo    String
  tipo      VideoType   @default(LARGO)
  estado    VideoStatus @default(GUIONADO)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  talentId  String
  editorId  String?
  talent    Talent      @relation(fields: [talentId], references: [id])
  editor    User?       @relation(fields: [editorId], references: [id])

  @@index([talentId])
  @@index([editorId])
  @@index([estado])
  @@index([tipo])
}

model Viewer {
  id           String             @id @default(cuid())
  platform     String
  platformId   String
  displayName  String?
  createdAt    DateTime           @default(now())
  points       ViewerPoints[]
  transactions PointTransaction[]

  @@unique([platform, platformId])
  @@index([displayName])
}

model ViewerPoints {
  viewerId    String
  talentId    String
  points      BigInt   @default(0)
  totalEarned BigInt   @default(0)
  totalSpent  BigInt   @default(0)
  updatedAt   DateTime @default(now()) @updatedAt
  viewer      Viewer   @relation(fields: [viewerId], references: [id], onDelete: Cascade)
  talent      Talent   @relation(fields: [talentId], references: [id], onDelete: Cascade)

  @@id([viewerId, talentId])
}

model PointTransaction {
  id        String   @id @default(cuid())
  viewerId  String
  talentId  String
  amount    Int
  reason    String
  platform  String
  metadata  Json?
  createdAt DateTime @default(now())
  viewer    Viewer   @relation(fields: [viewerId], references: [id], onDelete: Cascade)
  talent    Talent   @relation(fields: [talentId], references: [id], onDelete: Cascade)

  @@index([viewerId])
  @@index([talentId])
  @@index([createdAt])
}

model PointConfig {
  talentId              String @id
  pointsPerMessage      Int    @default(1)
  messageCooldownSec    Int    @default(30)
  watchIntervalMin      Int    @default(5)
  pointsPerWatchInterval Int   @default(5)
  pointsPerSub          Int    @default(500)
  pointsPerGiftedSub    Int    @default(500)
  pointsPerBit          Int    @default(1)
  pointsPerUsd          Float  @default(100)
  pointsPerMembership   Int    @default(500)
  pointsPerChannelPoint Float  @default(0.1)
  talent                Talent @relation(fields: [talentId], references: [id], onDelete: Cascade)
}
